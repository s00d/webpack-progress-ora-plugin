{
  "name": "webpack-progress-ora-plugin",
  "version": "2.0.1",
  "description": "A progress ora plugin for Webpack.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && cp dist/index.d.ts dist/index.d.cts",
    "demo": "npm run build && node scripts/demo.mjs",
    "demo:bar": "npm run build && node scripts/demo.mjs bar",
    "demo:clear": "npm run build && node scripts/demo.mjs clear",
    "record:gif": "bash scripts/record-gif.sh",
    "pretest": "npm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:package": "publint",
    "prepublishOnly": "npm run build && npm run lint:package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s00d/webpack-progress-ora-plugin.git"
  },
  "keywords": [
    "webpack",
    "plugin",
    "progress",
    "bar",
    "ora"
  ],
  "author": "Pavel Kuzmin <Virus191288@gmail.com> (https://github.com/s00d)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/s00d/webpack-progress-ora-plugin/issues"
  },
  "homepage": "https://github.com/s00d/webpack-progress-ora-plugin#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ora": "^9.4.1",
    "log-update": "^7.2.0"
  },
  "peerDependencies": {
    "webpack": "^5.108.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.21",
    "eslint": "^10.6.0",
    "globals": "^16.2.0",
    "publint": "^0.3.12",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.1",
    "webpack": "^5.108.4"
  }
}
